# Сборка Vite: переменные VITE_* подставляются при npm run build.
# Локально: npm run dev — /api проксируется на бэкенд (vite.config.ts).

# Timeweb S3 (библиотека шаблонов и превью). Без них libraryApi падает на дефолтный endpoint.
VITE_S3_ENDPOINT_URL=https://s3.twcstorage.ru
VITE_S3_BUCKET_NAME=

# Опционально: публичный базовый URL бакета, если отдаёте объекты по CDN/публичному URL.
# VITE_S3_PUBLIC_BASE_URL=

# Только если API на другом origin (не selfio.ru). На одном сервере с Nginx /api — не задавать.
# VITE_API_BASE_URL=
