# Async-драйвер для FastAPI (Alembic сам подменит на синхронный psycopg при миграциях).
DATABASE_URL=postgresql+psycopg_async://postgres:postgres@127.0.0.1:5432/selfio
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:5173
DEBUG=false

# --- Локальная разработка (Vite проксирует /api на uvicorn) ---
# Публичный URL бэкенда (redirect_uri OAuth, ссылки в письмах и т.п.).
PUBLIC_API_BASE=http://127.0.0.1:8000
# Страница фронта после OAuth (обмен code на JWT).
FRONTEND_OAUTH_CALLBACK_URL=http://localhost:5173/oauth/callback
# Базовый URL фронта для success после оплаты ЮMoney (если пусто — origin из FRONTEND_OAUTH_CALLBACK_URL).
FRONTEND_APP_URL=http://localhost:5173

# --- Прод: один VPS Timeweb, домен selfio.ru, Nginx отдаёт фронт и проксирует /api (см. deploy/timeweb/nginx-selfio.conf) ---
# PUBLIC_API_BASE=https://selfio.ru
# FRONTEND_OAUTH_CALLBACK_URL=https://selfio.ru/oauth/callback
# FRONTEND_APP_URL=https://selfio.ru
# CORS_ORIGINS=https://selfio.ru,https://www.selfio.ru
# YOOMONEY_SUCCESS_RETURN_URL=https://selfio.ru/app/profile?payment=ok
# В ЮMoney HTTP-уведомлениях URL: https://selfio.ru/api/payments/yoomoney/webhook

# ЮMoney (физлицо — quickpay + HTTP-уведомления):
# https://yoomoney.ru/docs/payment-buttons/using-api/forms
# Номер кошелька получателя и секрет из https://yoomoney.ru/transfer/myservices/http-notification
YOOMONEY_RECEIVER=
YOOMONEY_HTTP_NOTIFICATION_SECRET=
# Назначение платежа (targets) и способ оплаты по умолчанию: AC — карта, PC — кошелёк ЮMoney.
YOOMONEY_PAYMENT_TARGETS=Пополнение баланса токенов Selfio
YOOMONEY_PAYMENT_TYPE=AC
# Обычно не менять: страница quickpay для типа формы shop.
YOOMONEY_QUICKPAY_BASE_URL=https://yoomoney.ru/quickpay/confirm.xml
# Прод (отдельно от OAuth): полный successURL после оплаты для параметра successURL в quickpay.
# Пусто — тогда {FRONTEND_APP_URL или origin из FRONTEND_OAUTH_CALLBACK_URL}/app/profile?payment=ok
# YOOMONEY_SUCCESS_RETURN_URL=https://selfio.ru/app/profile?payment=ok
YOOMONEY_SUCCESS_RETURN_URL=
# Прод: только если вебхук ЮMoney на другом хосте, чем PUBLIC_API_BASE. На одном домене selfio.ru — не нужен.
# В кабинете ЮMoney: {PUBLIC_API_BASE}/api/payments/yoomoney/webhook  (напр. https://selfio.ru/api/payments/yoomoney/webhook)
# YOOMONEY_WEBHOOK_BASE_URL=https://api.selfio.ru
YOOMONEY_WEBHOOK_BASE_URL=

# Яндекс OAuth: https://oauth.yandex.ru/ — Callback URL = {PUBLIC_API_BASE}/api/auth/oauth/yandex/callback
YANDEX_OAUTH_CLIENT_ID=
YANDEX_OAUTH_CLIENT_SECRET=

# Google OAuth (Google Cloud Console): Authorized redirect URI = {PUBLIC_API_BASE}/api/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# VK ID (единый вход ВК + Mail и др.): https://id.vk.com/ — приложение и redirect в кабинете VK ID.
# Доверенный redirect URL в кабинете ДОЛЖЕН совпадать с:
#   {PUBLIC_API_BASE}/api/auth/oauth/vkid/callback
# Локальная разработка: VK ID в кабинете часто не принимает http://127.0.0.1:8000/...
# Варианты: (1) HTTPS-туннель к локальному API (ngrok, cloudflare tunnel) и второй redirect в кабинете;
# (2) тестировать VK ID только на задеплоенном https://api.selfio.ru с тем же VK_ID_OAUTH_CLIENT_ID.
# Документация: https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/start-integration/auth-without-sdk/auth-without-sdk-web
VK_ID_OAUTH_CLIENT_ID=

# Timeweb S3: https://timeweb.cloud/docs/s3-storage/sdk/python
# В доке endpoint по умолчанию https://s3.twcstorage.ru (можно оставить или задать S3_ENDPOINT_URL).
# Панель часто даёт BUCKET_NAME, S3_ACCESS_KEY, S3_SECRET_ACCESS_KEY.
# Допустимо как у AWS: AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY.
S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_REGION=ru-1
BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
# Для вкладки «Мои фото»: в CORS бакета добавьте GET (presigned URL открывается из браузера).
# Presign и галерея используют ключи вида: S3_selfio/users/<uuid>/user_photo/<файл>
# (результаты генераций: S3_selfio/users/<uuid>/result_generation/).
#
# Витрина «Библиотека» в приложении читает файлы из бакета по путям (можно загружать через панель Timeweb):
#   S3_selfio/library/portrait/
#   S3_selfio/library/landscape/
#   S3_selfio/library/family/
#   S3_selfio/library/style/
# Допустимые расширения: jpg, jpeg, png, webp, gif, heic, heif. Без S3_PUBLIC_BASE_URL ссылки на превью — presigned (7 дней).
