# Один целый /etc/nginx/nginx.conf для VPS только под Selfio (ничего из sites-enabled не подключается).
# Сохранить как /etc/nginx/nginx.conf, затем: nginx -t && systemctl reload nginx
#
# Перед этим: поправьте пути ssl_certificate / ssl_certificate_key и при необходимости root.
# Если nginx -t ругается на modules-enabled — закомментируйте строку include modules-enabled.
#
# Если нужны другие сайты — раскомментируйте include в конце блока http и вынесите лишние server в отдельные файлы.

user www-data;
worker_processes auto;
pid /run/nginx.pid;
error_log /var/log/nginx/error.log;
include /etc/nginx/modules-enabled/*.conf;

events {
    worker_connections 768;
}

http {
    sendfile on;
    tcp_nopush on;
    types_hash_max_size 2048;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    access_log /var/log/nginx/access.log;

    gzip on;
    gzip_vary on;
    gzip_min_length 256;
    gzip_comp_level 5;
    gzip_types
        text/plain
        text/css
        application/javascript
        application/json
        image/svg+xml
        font/woff2;

    # Закомментировано: весь сайт описан ниже в этом файле (без сборки из sites-available).
    # include /etc/nginx/conf.d/*.conf;
    # include /etc/nginx/sites-enabled/*;

    server {
        listen 443 ssl http2;
        server_name www.selfio.ru;

        ssl_certificate     /etc/ssl/selfio/fullchain.pem;
        ssl_certificate_key /etc/ssl/selfio/privkey.pem;

        return 301 https://selfio.ru$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name selfio.ru;

        ssl_certificate     /etc/ssl/selfio/fullchain.pem;
        ssl_certificate_key /etc/ssl/selfio/privkey.pem;

        root /var/www/selfio/dist;
        index index.html;

        client_max_body_size 80m;

        gzip on;
        gzip_vary on;
        gzip_min_length 256;
        gzip_comp_level 5;
        gzip_types
            text/plain
            text/css
            application/javascript
            application/json
            image/svg+xml
            font/woff2;

        location = /index.html {
            add_header Cache-Control "no-store" always;
        }

        location /assets/ {
            add_header Cache-Control "public, max-age=31536000, immutable" always;
            access_log off;
            try_files $uri =404;
        }

        location /fonts/ {
            add_header Cache-Control "public, max-age=31536000, immutable" always;
            try_files $uri =404;
        }

        location /api/ {
            proxy_pass http://127.0.0.1:8000;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # SPA иначе отдаёт index.html на любой путь — сканеры видят «200» на /.git, /.env и т.д.; режем типичные точечные пути.
        # Не трогаем /.well-known (Certbot / проверки домена): он не попадает под эти шаблоны.
        location ~* /\.(git|env|vite|idea|vscode|DS_Store) {
            return 404;
        }

        location / {
            try_files $uri $uri/ /index.html;
        }
    }

    server {
        listen 80;
        server_name selfio.ru www.selfio.ru;
        return 301 https://selfio.ru$request_uri;
    }
}
